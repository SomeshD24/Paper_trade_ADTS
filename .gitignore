# 1. Ignore EVERYTHING in the root directory by default
/*

# 2. Allow Git to read these specific folders and files in the root
!/evaluation/
!/state/
!/.gitignore
!/requirements.txt
!/strategy1_dualbasket2.py
!/baskets_nifty200_all_sizes.csv

# 3. Ignore everything inside the state folder...
/state/*
# ...EXCEPT the exact quantities file
!/state/basket_quantities_6.json

# 4. Global rules to block cache/secrets (even inside allowed folders)
__pycache__/
*.pyc
.env
.venv/
